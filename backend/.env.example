# Copy to .env locally. On Render: set in Environment → Environment Variables (never commit real values).

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret_from_supabase_api_settings

# Comma-separated origins allowed to call this API (your Vercel URL(s) + local dev).
# Example: https://vista.vercel.app,https://vista-xxx.vercel.app,http://127.0.0.1:5173
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Optional: print config on startup (do not enable in production with secrets visible in logs)
# DEBUG=1
