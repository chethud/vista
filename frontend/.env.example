# Copy to .env and fill in. For Vercel: set these in Project → Settings → Environment Variables.

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# FastAPI on Render — no trailing slash (e.g. https://vista-backend.onrender.com)
VITE_BACKEND_URL=http://127.0.0.1:8000
